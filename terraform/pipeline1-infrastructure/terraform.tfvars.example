project_name = "taskmanager"
environment  = "dev"
location     = "centralus"

vnet_address_space          = ["10.30.0.0/16"]
aci_subnet_address_prefixes = ["10.30.1.0/24"]

# Pipeline 1 uses a public bootstrap image so infrastructure can be created
# before Pipeline 2 publishes the real application image.
container_image = "mcr.microsoft.com/azuredocs/aci-helloworld:latest"
container_port  = 80
